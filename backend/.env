    FOREIGN KEY (user_id) REFERENCES users(id)
);
❤️ 11) post_likes
sql
CREATE TABLE post_likes (
    id INT PRIMARY KEY AUTO_INCREMENT,
    post_id INT NOT NULL,
    user_id INT NOT NULL,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,

    FOREIGN KEY (post_id) REFERENCES posts(id),
    FOREIGN KEY (user_id) REFERENCES users(id)
);
💬 12) comments
sql
CREATE TABLE comments (
    id INT PRIMARY KEY AUTO_INCREMENT,
    post_id INT NOT NULL,
    user_id INT NOT NULL,
    content TEXT NOT NULL,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    is_anonymous TINYINT(1) DEFAULT 0,
    anon_name VARCHAR(100),

    FOREIGN KEY (post_id) REFERENCES posts(id),
    FOREIGN KEY (user_id) REFERENCES users(id)
);
🔁 13) habits
sql
CREATE TABLE habits (
    id INT PRIMARY KEY AUTO_INCREMENT,
    user_id INT NOT NULL,
    name VARCHAR(255) NOT NULL,
    type VARCHAR(50),
    category VARCHAR(50),
    emoji VARCHAR(10),
    color VARCHAR(20),
    frequency VARCHAR(50),
    difficulty INT,
    reminder_time TIME,
    is_private TINYINT(1) DEFAULT 0,
    motivation TEXT,
    triggers TEXT,
    relapse_plan TEXT,
    danger_level INT,
    is_active TINYINT(1) DEFAULT 1,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    times_per_day INT DEFAULT 1,
    start_date DATE,
    spark_count INT DEFAULT 0,

    FOREIGN KEY (user_id) REFERENCES users(id)
);
📘 14) habit_logs
sql
CREATE TABLE habit_logs (
    id INT PRIMARY KEY AUTO_INCREMENT,
    habit_id INT NOT NULL,
    user_id INT NOT NULL,
    type VARCHAR(50),
    note TEXT,
    logged_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,

    FOREIGN KEY (habit_id) REFERENCES habits(id),
    FOREIGN KEY (user_id) REFERENCES users(id)
);
⭐ 15) habit_milestones
sql
CREATE TABLE habit_milestones (
    id INT PRIMARY KEY AUTO_INCREMENT,
    habit_id INT NOT NULL,
    user_id INT NOT NULL,
    days INT NOT NULL,
    reached_at DATETIME,

    FOREIGN KEY (habit_id) REFERENCES habits(id),
    FOREIGN KEY (user_id) REFERENCES users(id)
);
📅 16) task_daily_state
sql
CREATE TABLE task_daily_state (
    task_id INT NOT NULL,
    user_id INT NOT NULL,
    date DATE NOT NULL,
    count INT DEFAULT 0,
    done TINYINT(1) DEFAULT 0,

    PRIMARY KEY (task_id, user_id, date),
    FOREIGN KEY (task_id) REFERENCES tasks(id),
    FOREIGN KEY (user_id) REFERENCES users(id)
);
👥 17) groups
sql
CREATE TABLE groups (
    id INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(255) NOT NULL,
    description TEXT,
    emoji VARCHAR(10),
    category VARCHAR(50),
    is_private TINYINT(1) DEFAULT 0,
    created_by INT NOT NULL,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,

    FOREIGN KEY (created_by) REFERENCES users(id)
);
👤 18) group_members
sql
CREATE TABLE group_members (
    id INT PRIMARY KEY AUTO_INCREMENT,
    group_id INT NOT NULL,
    user_id INT NOT NULL,
    role VARCHAR(50) DEFAULT 'member',
    joined_at DATETIME DEFAULT CURRENT_TIMESTAMP,

    FOREIGN KEY (group_id) REFERENCES groups(id),
    FOREIGN KEY (user_id) REFERENCES users(id)
);
📝 19) posts
sql
CREATE TABLE posts (
    id INT PRIMARY KEY AUTO_INCREMENT,
    user_id INT NOT NULL,
    content TEXT NOT NULL,
    type VARCHAR(50),
    ref_id INT,
    likes_count INT DEFAULT 0,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    group_id INT,
    is_anonymous TINYINT(1) DEFAULT 0,
    anon_name VARCHAR(100),

    FOREIGN KEY (user_id) REFERENCES users(id),
    FOREIGN KEY (group_id) REFERENCES groups(id)
);
🎨 20) task_themes
sql
CREATE TABLE task_themes (
    task_id INT NOT NULL,
    theme_id INT NOT NULL,

    PRIMARY KEY (task_id, theme_id),
    FOREIGN KEY (task_id) REFERENCES tasks(id),
    FOREIGN KEY (theme_id) REFERENCES themes(id)
);
🎨 21) habit_themes
sql
CREATE TABLE habit_themes (
    habit_id INT NOT NULL,
    theme_id INT NOT NULL,

    PRIMARY KEY (habit_id, theme_id),
    FOREIGN KEY (habit_id) REFERENCES habits(id),
    FOREIGN KEY (theme_id) REFERENCES themes(id)
);
🛠️ 22) _prisma_migrations
sql
CREATE TABLE _prisma_migrations (
    id VARCHAR(36) PRIMARY KEY,
    checksum VARCHAR(64) NOT NULL,
    finished_at DATETIME,
    migration_name VARCHAR(255) NOT NULL,
    logs TEXT,
    rolled_back_at DATETIME,
    started_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    applied_steps_count INT DEFAULT 0
);


