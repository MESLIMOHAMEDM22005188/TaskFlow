🧱 1) users
sql
CREATE TABLE users (
    id INT PRIMARY KEY AUTO_INCREMENT,
    email VARCHAR(255) NOT NULL UNIQUE,
    password VARCHAR(255) NOT NULL,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    username VARCHAR(100) NOT NULL,
    bio TEXT DEFAULT NULL,
    avatar_url VARCHAR(255) DEFAULT NULL,
    xp INT DEFAULT 0,
    top3_count INT DEFAULT 0,

    accent_color VARCHAR(20) DEFAULT '#6366f1',
    bg_preset VARCHAR(50) DEFAULT 'navy',
    dark_mode TINYINT(1) DEFAULT 1,
    compact_mode TINYINT(1) DEFAULT 0,
    reduced_motion TINYINT(1) DEFAULT 0,
    language VARCHAR(10) DEFAULT 'fr',

    notif_habits TINYINT(1) DEFAULT 1,
    notif_milestones TINYINT(1) DEFAULT 1,
    notif_community_likes TINYINT(1) DEFAULT 1,
    notif_community_comments TINYINT(1) DEFAULT 1,
    notif_flow_reminders TINYINT(1) DEFAULT 0,
    notif_weekly_recap TINYINT(1) DEFAULT 1,
    notif_relapse_support TINYINT(1) DEFAULT 1,

    privacy_profile_public TINYINT(1) DEFAULT 1,
    privacy_show_xp TINYINT(1) DEFAULT 1,
    privacy_show_streaks TINYINT(1) DEFAULT 1,
    privacy_appear_leaderboard TINYINT(1) DEFAULT 1,
    privacy_default_posts_private TINYINT(1) DEFAULT 0,
    privacy_default_habits_private TINYINT(1) DEFAULT 0
);
🎨 2) themes
sql
CREATE TABLE themes (
    id INT PRIMARY KEY AUTO_INCREMENT,
    user_id INT NOT NULL,
    name VARCHAR(100) NOT NULL,
    emoji VARCHAR(10),
    color VARCHAR(20),
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,

    FOREIGN KEY (user_id) REFERENCES users(id)
);
📝 3) tasks
sql
CREATE TABLE tasks (
    id INT PRIMARY KEY AUTO_INCREMENT,
    user_id INT NOT NULL,
    theme_id INT,
    title VARCHAR(255) NOT NULL,
    priority INT DEFAULT 0,
    frequency VARCHAR(50),
    deadline DATETIME,
    note TEXT,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    status VARCHAR(50) DEFAULT 'pending',
    completion_target INT DEFAULT 1,
    completions_count INT DEFAULT 0,
    completed_at DATETIME,
    archived_at DATETIME,

    FOREIGN KEY (user_id) REFERENCES users(id),
    FOREIGN KEY (theme_id) REFERENCES themes(id)
);
🔁 4) task_completions
sql
CREATE TABLE task_completions (
    id INT PRIMARY KEY AUTO_INCREMENT,
    task_id INT NOT NULL,
    user_id INT NOT NULL,
    completed_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    note TEXT,

    FOREIGN KEY (task_id) REFERENCES tasks(id),
    FOREIGN KEY (user_id) REFERENCES users(id)
);
🏆 5) achievements
sql
CREATE TABLE achievements (
    id INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(150) NOT NULL,
    description TEXT,
    goal INT NOT NULL,
    level INT NOT NULL,
    type VARCHAR(50) NOT NULL
);
🏅 6) user_achievements
sql
CREATE TABLE user_achievements (
    id INT PRIMARY KEY AUTO_INCREMENT,
    user_id INT NOT NULL,
    achievement_id INT NOT NULL,
    progress INT DEFAULT 0,
    completed TINYINT(1) DEFAULT 0,
    completed_at DATETIME,

    FOREIGN KEY (user_id) REFERENCES users(id),
    FOREIGN KEY (achievement_id) REFERENCES achievements(id)
);
🎯 7) objective_templates
sql
CREATE TABLE objective_templates (
    id INT PRIMARY KEY AUTO_INCREMENT,
    title VARCHAR(255) NOT NULL,
    description TEXT,
    category VARCHAR(50),
    emoji VARCHAR(10),
    suggested_days INT,
    target_value INT,
    target_unit VARCHAR(50)
);
🎯 8) objectives
sql
CREATE TABLE objectives (
    id INT PRIMARY KEY AUTO_INCREMENT,
    user_id INT NOT NULL,
    template_id INT,
    title VARCHAR(255),
    description TEXT,
    emoji VARCHAR(10),
    theme_id INT,
    target_value INT,
    current_value INT DEFAULT 0,
    target_unit VARCHAR(50),
    deadline DATETIME,
    status VARCHAR(50) DEFAULT 'active',
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,

    FOREIGN KEY (user_id) REFERENCES users(id),
    FOREIGN KEY (template_id) REFERENCES objective_templates(id),
    FOREIGN KEY (theme_id) REFERENCES themes(id)
);
